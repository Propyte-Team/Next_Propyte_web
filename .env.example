# ===========================================
# Next_Propyte_web — Environment Variables
# ===========================================
# Copy to .env.local and fill in real values
# NEVER commit .env.local to the repository
# ===========================================

# --- Supabase (read-only for frontend) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# --- Google Maps (obligatorio — indexación) ---
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=AIza-your-key-here

# --- Revalidation (shared secret with Propyte_hub) ---
REVALIDATION_SECRET=your-revalidation-secret-here

# --- Analytics (optional) ---
NEXT_PUBLIC_GA4_ID=G-H4VD5TVEKM
NEXT_PUBLIC_META_PIXEL_ID=XXXXXXXXXXXXXXXXX
NEXT_PUBLIC_HOTJAR_ID=XXXXXXX

# --- Google Ads (conversiones) ---
# Tag de la cuenta Nativa Tulum + acción "Lead formulario web".
# NEXT_PUBLIC_* se inlinean en build — deben existir donde se corre `next build`.
NEXT_PUBLIC_GOOGLE_ADS_ID=AW-11009183156
NEXT_PUBLIC_GOOGLE_ADS_CONVERSION_LEAD=AW-11009183156/XXXXXXXXXXXXXXXXXXX

# --- WhatsApp ---
NEXT_PUBLIC_WHATSAPP_PHONE=529844638032

# --- Webhook (form submissions) ---
NEXT_PUBLIC_WEBHOOK_URL=https://hub.propyte.com/api/leads

# --- Rental scraper API (protege /api/rental-comparables) ---
RENTAL_SCRAPER_API_KEY=your-rental-scraper-key-here

# --- Hub connection ---
HUB_API_URL=https://hub.propyte.com
HUB_API_KEY=your-hub-api-key-here

# --- Email (Nodemailer + Hostinger SMTP) ---
SMTP_HOST=mail.propyte.com
SMTP_PORT=465
SMTP_USER=contacto@propyte.com
SMTP_PASS=your-smtp-password-here

# --- Site ---
NEXT_PUBLIC_SITE_URL=https://propyte.com

# --- Blog staging preview ---
# Poner 'true' SOLO en dev.propyte.com (Vercel) para ver posts con status='staged'.
# En producción (propyte.com / Hostinger) dejar vacío o no definir.
BLOG_INCLUDE_STAGED=false

# --- Hero background (3-tier fallback: video → image → gradient) ---
# Cuando se configura video, la imagen se usa como poster
NEXT_PUBLIC_HERO_VIDEO_URL=
NEXT_PUBLIC_HERO_IMAGE_URL=

# --- Zoho CRM (formularios web → /api/leads → Zoho) ---
ZOHO_CLIENT_ID=your-zoho-client-id
ZOHO_CLIENT_SECRET=your-zoho-client-secret
ZOHO_REFRESH_TOKEN=your-zoho-refresh-token
# Defaults: https://www.zohoapis.com/crm/v2  /  https://accounts.zoho.com  /  2000
ZOHO_API_BASE_URL=https://www.zohoapis.com/crm/v2
ZOHO_ACCOUNTS_URL=https://accounts.zoho.com
ZOHO_DAILY_API_LIMIT=2000

# --- Cron (reintento de leads con sync fallida: /api/cron/zoho-retry) ---
# Mín. 32 chars. El crontab de Hostinger lo manda vía header `x-cron-secret`
# (el CDN stripea `Authorization: Bearer`). Generar con: openssl rand -hex 32
CRON_SECRET=your-cron-secret-min-32-chars

# --- Banxico SIE API (tipo de cambio USD/MXN referencial en precios) ---
# OBLIGATORIO: sin token la API responde 400 y el sitio usa el rate FALLBACK
# hardcodeado (stale). Token gratuito: https://www.banxico.org.mx/SieAPIRest/
# → "Obtén tu token". Configurar también en el panel de Hostinger (prod).
BANXICO_TOKEN=your-banxico-sie-token
